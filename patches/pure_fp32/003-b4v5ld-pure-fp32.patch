+// MIXED-PRECISION Phase 2+: fp32 transcendental math
+#define B4V5_FP32_MATH
+#ifdef B4V5_FP32_MATH
+#undef SPICE_EXP
+#undef SPICE_LOG
+#undef SPICE_SQRT
+#undef SPICE_POW
+#undef SPICE_SIN
+#undef SPICE_COS
+#undef SPICE_FABS
+#undef SPICE_ATAN
+#undef SPICE_TAN
+#undef SPICE_TANH
+#define SPICE_EXP(x)  expf((float)(x))
+#define SPICE_LOG(x)  logf((float)(x))
+#define SPICE_SQRT(x) sqrtf((float)(x))
+#define SPICE_POW(x,y) powf((float)(x),(float)(y))
+#define SPICE_SIN(x)  sinf((float)(x))
+#define SPICE_COS(x)  cosf((float)(x))
+#define SPICE_FABS(x) fabsf((float)(x))
+#define SPICE_ATAN(x) atanf((float)(x))
+#define SPICE_TAN(x)  tanf((float)(x))
+#define SPICE_TANH(x) tanhf((float)(x))
+#undef DEXP
+#define DEXP(A,B,C) { \
+    if ((A) > EXP_THRESHOLD) { \
+        B = (SPICE_REAL)(MAX_EXP*(1.0f+(float)(A)-EXP_THRESHOLD)); \
+        C = (SPICE_REAL)MAX_EXP; \
+    } else if ((A) < -EXP_THRESHOLD) { \
+        B = (SPICE_REAL)MIN_EXP; \
+        C = 0.0; \
+    } else { \
+        B = (SPICE_REAL)expf((float)(A)); \
+        C = B; \
+    } \
+}
+#endif
+
+/* FP32 NaN tracking: detect and log NaN, reset to zero to prevent cascade */
+#define CHECK_NAN(var) \
+    if (isnan((float)(var))) { \
+        fprintf(stderr, "FP32-NAN(pure): %s at %s:%d  val=%g\n", #var, __FILE__, __LINE__, (float)(var)); \
+        var = 0.0; \
+    }
