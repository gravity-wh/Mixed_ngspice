    when(lg_raw != nil
        lg_mag = db20(lg_raw)
        ugf_cross = cross(lg_mag 0 1 "falling" nil 0.0)
        when(numberp(ugf_cross)
            ugf_h1 = ugf_cross
        )
        when(drIsWaveform(ugf_cross)
            ugf_vec = drGetWaveformYVec(ugf_cross)
            when(ugf_vec != nil
                ugf_h1 = drGetElem(ugf_vec 0)
            )
        )
    )
)

printf("PM_H1    = %.4f Deg\n" pm_h1)
printf("GM_H1    = %.4f dB\n" gm_h1)
printf("UGF_H1   = %.4f Hz\n" ugf_h1)

