; TB5: STB HORDER Stability Analysis
; 12 independent STB loops covering all HORDER iprobe locations
; Extracts PM (deg), GM (dB), and UGF (Hz) for each loop
; BGR + HORDER joint simulation, 27C, TT corner
; Reference: indicator.json key "TB5"

simulator('spectre)

; Initialize all FOM variables
pm_cont = 0.0
gm_cont = 0.0
ugf_cont = 0.0
pm_h1 = 0.0
gm_h1 = 0.0
ugf_h1 = 0.0
pm_h3_amp = 0.0
gm_h3_amp = 0.0
ugf_h3_amp = 0.0
pm_h4_amp1 = 0.0
gm_h4_amp1 = 0.0
ugf_h4_amp1 = 0.0
pm_h5_amp1 = 0.0
gm_h5_amp1 = 0.0
ugf_h5_amp1 = 0.0
pm_adder = 0.0
gm_adder = 0.0
ugf_adder = 0.0
pm_h3 = 0.0
gm_h3 = 0.0
ugf_h3 = 0.0
pm_h4 = 0.0
gm_h4 = 0.0
ugf_h4 = 0.0
pm_h4_amp2 = 0.0
gm_h4_amp2 = 0.0
ugf_h4_amp2 = 0.0
pm_h5 = 0.0
gm_h5 = 0.0
ugf_h5 = 0.0
pm_h5_amp2 = 0.0
gm_h5_amp2 = 0.0
ugf_h5_amp2 = 0.0
pm_center = 0.0
gm_center = 0.0
ugf_center = 0.0

openResults("/share/home/chentianyang/nloa/testdata_input/psf_data/tb5_stb_horder")

; =============================
; Function: extract PM and GM from margin results
; =============================
printf("\n===== STB Loop Results =====\n")

; ----- CONT Loop -----
sr = selectResults("stb-margin.stb")
when(sr != nil
    pm_raw = getData("phaseMargin")
    when(pm_raw != nil
        pm_cont = value(pm_raw 0)
    )
    gm_raw = getData("gainMargin")
    when(gm_raw != nil
        gm_cont = value(gm_raw 0)
    )
)

sr_ugf = selectResults("stb-stb")
when(sr_ugf != nil
    lg_raw = getData("loopGain")
    when(lg_raw != nil
        lg_mag = db20(lg_raw)
        ugf_cross = cross(lg_mag 0 1 "falling" nil 0.0)
        when(numberp(ugf_cross)
            ugf_cont = ugf_cross
        )
        when(drIsWaveform(ugf_cross)
            ugf_vec = drGetWaveformYVec(ugf_cross)
            when(ugf_vec != nil
                ugf_cont = drGetElem(ugf_vec 0)
            )
        )
    )
)

printf("PM_CONT  = %.4f Deg\n" pm_cont)
printf("GM_CONT  = %.4f dB\n" gm_cont)
printf("UGF_CONT = %.4f Hz\n" ugf_cont)

; ----- H1 Loop -----
sr = selectResults("stb_h1-margin.stb")
when(sr != nil
    pm_raw = getData("phaseMargin")
    when(pm_raw != nil
        pm_h1 = value(pm_raw 0)
    )
    gm_raw = getData("gainMargin")
    when(gm_raw != nil
        gm_h1 = value(gm_raw 0)
    )
)

