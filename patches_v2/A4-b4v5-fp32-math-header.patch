--- /dev/null	2026-07-19 09:30:53.010362813 +0800
+++ b/src/spicelib/devices/bsim4v5/b4v5_fp32_math.h	2026-07-20 15:04:27.533426738 +0800
@@ -0,0 +1,32 @@
+/* MIXED-PRECISION: FP32 transcendental math overrides
+ * Included by: b4v5ld.c, b4v5temp.c, b4v5noi.c, b4v5pzld.c, b4v5acld.c
+ * Eliminates 5x25=125 lines of duplicated macro definitions across 5 files.
+ */
+#ifndef B4V5_FP32_MATH_H
+#define B4V5_FP32_MATH_H
+
+#define B4V5_FP32_MATH
+#ifdef B4V5_FP32_MATH
+#undef SPICE_EXP
+#undef SPICE_LOG
+#undef SPICE_SQRT
+#undef SPICE_POW
+#undef SPICE_SIN
+#undef SPICE_COS
+#undef SPICE_FABS
+#undef SPICE_ATAN
+#undef SPICE_TAN
+#undef SPICE_TANH
+#define SPICE_EXP(x)  expf((float)(x))
+#define SPICE_LOG(x)  logf((float)(x))
+#define SPICE_SQRT(x) sqrtf((float)(x))
+#define SPICE_POW(x,y) powf((float)(x),(float)(y))
+#define SPICE_SIN(x)  sinf((float)(x))
+#define SPICE_COS(x)  cosf((float)(x))
+#define SPICE_FABS(x) fabsf((float)(x))
+#define SPICE_ATAN(x) atanf((float)(x))
+#define SPICE_TAN(x)  tanf((float)(x))
+#define SPICE_TANH(x) tanhf((float)(x))
+#endif
+
+#endif /* B4V5_FP32_MATH_H */
